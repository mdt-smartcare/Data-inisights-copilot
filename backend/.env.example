# ============================================
# Application Configuration
# ============================================
PROJECT_NAME=Data Insights Copilot
VERSION=1.0.0
DEBUG=true
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1

# ============================================
# Database Configuration
# ============================================
# Internal PostgreSQL database for app data (users, agents, configs)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=copilot
POSTGRES_USER=admin
POSTGRES_PASSWORD=admin

# Database connection pool settings
POSTGRES_POOL_SIZE=10
POSTGRES_MAX_OVERFLOW=20
POSTGRES_POOL_TIMEOUT=30
POSTGRES_POOL_RECYCLE=3600
POSTGRES_ECHO=false

# ============================================
# Security & Authentication
# ============================================
# JWT Secret Key (CHANGE IN PRODUCTION!)
SECRET_KEY=your-secret-key-here-change-in-production

# JWT Configuration
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================
# OIDC/Keycloak Configuration
# ============================================
# Leave empty to disable OIDC authentication
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=data-insights-copilot
OIDC_AUDIENCE=
OIDC_JWKS_CACHE_TTL=3600
OIDC_DEFAULT_ROLE=user
OIDC_ROLE_CLAIM=realm_access.roles

# ============================================
# CORS Configuration
# ============================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ============================================
# OpenAI Configuration
# ============================================
OPENAI_API_KEY=sk-your-openai-api-key-here

# ============================================
# Observability - Langfuse (Optional)
# ============================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ============================================
# Observability - OpenTelemetry (Optional)
# ============================================
# OTLP_ENDPOINT=http://localhost:4317
# OTEL_SERVICE_NAME=fhir-rag-api

# ============================================
# File Storage
# ============================================
DATA_DIR=./data
INDEXES_PATH=./data/indexes

# ============================================
# Development Settings
# ============================================
# Set to true to reload on code changes (uvicorn --reload)
RELOAD=true
