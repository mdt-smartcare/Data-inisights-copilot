# ============================================================================
# Backend Service Environment Configuration
# ============================================================================
# Copy this file to .env and fill in your values
# NEVER commit .env to version control
#
# This file contains INFRASTRUCTURE settings only - required for server startup.
#
# RUNTIME SETTINGS (LLM, embedding, RAG, chunking, etc.) are stored in the
# database `system_settings` table and configured via the frontend Settings page.
#
# CLINICAL DATABASE CONNECTIONS are managed via the `db_connections` table
# and assigned to agents via the frontend. Not configured here.
# ============================================================================

# ============================================================================
# API KEYS & SECRETS (Required)
# ============================================================================
# OpenAI API Key - Required for LLM functionality
OPENAI_API_KEY=sk-your-openai-api-key-here

# JWT Secret Key - Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-for-jwt-signing-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=720
REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================================
# INTERNAL APP DATABASE (SQLite - for config storage)
# ============================================================================
# Path to SQLite database for storing users, settings, prompts, agents, etc.
# This is NOT the clinical data database (that's configured via db_connections)
SQLITE_DB_PATH=./sqliteDb/copilot.db

# ============================================================================
# OIDC/KEYCLOAK AUTHENTICATION (Optional)
# ============================================================================
# Leave OIDC_ISSUER_URL empty to disable OIDC and use local auth
OIDC_ISSUER_URL=
OIDC_CLIENT_ID=data-insights-copilot
OIDC_AUDIENCE=
OIDC_JWKS_CACHE_TTL=3600
OIDC_DEFAULT_ROLE=user
OIDC_ROLE_CLAIM=realm_access.roles

# ============================================================================
# SERVER CONFIGURATION
# ============================================================================
HOST=0.0.0.0
PORT=8000
API_V1_PREFIX=/api/v1
PROJECT_NAME=Data Insights Copilot
VERSION=1.0.0
DEBUG=false

# ============================================================================
# CORS CONFIGURATION
# ============================================================================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,PUT,PATCH,DELETE,OPTIONS
CORS_ALLOW_HEADERS=*

# ============================================================================
# LANGFUSE TRACING (Optional)
# ============================================================================
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
ENABLE_LANGFUSE=false

# ============================================================================
# FILE PATHS
# ============================================================================
LOG_FILE=./logs/backend.log
EMBEDDING_LOG_FILE=./logs/embedding.log
MODELS_PATH=./models
DATA_PATH=./data

# ============================================================================
# FEATURE FLAGS
# ============================================================================
ENABLE_FOLLOWUP_QUESTIONS=true

# ============================================================================
# TESTING
# ============================================================================
TEST_DATABASE_URL=
PYTEST_TIMEOUT=30
