# ============================================================================
# Frontend Environment Configuration
# ============================================================================
# Copy this file to .env and update with your values
# NEVER commit .env to version control
# ============================================================================

# ============================================================================
# API Configuration
# ============================================================================
# Backend API URL
# For Docker: use "http://localhost:8000" (or your deployed backend URL)
# For Local development: use "http://localhost:8000"
VITE_API_BASE_URL=http://localhost:8000

# ============================================================================
# Timezone Configuration
# ============================================================================
# Set the timezone for displaying dates and times in the application
# If not set, will use the browser's local timezone
# Examples: America/New_York, Europe/London, Asia/Kolkata, UTC
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
VITE_TIMEZONE=Asia/Kolkata

# ============================================================================
# Authentication Mode
# ============================================================================
# Set to "local" for built-in auth, "oidc" for Keycloak/OIDC
# If using local auth, you can ignore the OIDC settings below
VITE_AUTH_MODE=local

# ============================================================================
# Keycloak/OIDC Configuration (Optional - only if VITE_AUTH_MODE=oidc)
# ============================================================================
# Update these values based on your Keycloak setup
VITE_OIDC_AUTHORITY=https://your-keycloak-server/realms/your-realm
VITE_OIDC_CLIENT_ID=data-insights-copilot
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
VITE_OIDC_SCOPE=openid profile email

# ============================================================================
# Feature Flags (Optional)
# ============================================================================
VITE_ENABLE_DARK_MODE=true
VITE_ENABLE_ANALYTICS=false