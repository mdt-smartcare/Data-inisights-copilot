# Example environment variables
# Copy this file to .env and update with your values

# API Configuration
VITE_API_BASE_URL=http://localhost:8000

# Timezone Configuration
# Set the timezone for displaying dates and times in the application
# If not set, will use the browser's local timezone
# Examples: America/New_York, Europe/London, Asia/Kolkata, UTC
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
VITE_TIMEZONE=Asia/Kolkata

# Keycloak OIDC Configuration
# Update these values based on your Keycloak setup
VITE_OIDC_AUTHORITY=https://keycloak.mdtlabs.org/realms/smartcare
VITE_OIDC_CLIENT_ID=smartcare-client
VITE_OIDC_REDIRECT_URI=http://localhost:5173/callback
VITE_OIDC_POST_LOGOUT_REDIRECT_URI=http://localhost:5173/login
VITE_OIDC_SCOPE=openid profile email data-insights