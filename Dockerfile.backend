# ── Build stage (install deps in a clean layer) ──────────────────────────────
FROM python:3.10.19-slim AS builder

WORKDIR /app

# System libs needed to compile native wheels (including MySQL client)
RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc g++ git curl libpq-dev build-essential \
    default-libmysqlclient-dev pkg-config \
    && rm -rf /var/lib/apt/lists/*

COPY requirements.txt .
RUN pip install --no-cache-dir --upgrade pip && \
    pip install --no-cache-dir -r requirements.txt

# ── Production stage ─────────────────────────────────────────────────────────
FROM python:3.10.19-slim

WORKDIR /app

# Runtime-only system deps (including MySQL client library)
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl libpq5 default-mysql-client libmariadb3 \
    && rm -rf /var/lib/apt/lists/*

# Copy installed packages from builder
COPY --from=builder /usr/local/lib/python3.10/site-packages /usr/local/lib/python3.10/site-packages
COPY --from=builder /usr/local/bin /usr/local/bin

# Copy backend source
COPY backend/ ./backend/

# Copy shared constants
COPY shared/ ./shared/

# Copy database migrations
COPY migrations/ ./migrations/

# Create runtime directories
RUN mkdir -p /app/backend/logs \
    /app/backend/data/indexes \
    /app/backend/sqliteDb \
    /app/backend/models

# Non-root user for security
RUN adduser --disabled-password --gecos '' appuser && \
    chown -R appuser:appuser /app
USER appuser

# Environment
ENV PYTHONUNBUFFERED=1
ENV PYTHONPATH=/app

EXPOSE 8000

# Health check
HEALTHCHECK --interval=30s --timeout=10s --start-period=40s --retries=3 \
    CMD curl -f http://localhost:8000/health || exit 1

# Production: Gunicorn with Uvicorn workers (4 workers, scalable)
CMD ["gunicorn", "backend.app.app:app", \
    "--worker-class", "uvicorn.workers.UvicornWorker", \
    "--workers", "4", \
    "--bind", "0.0.0.0:8000", \
    "--timeout", "120", \
    "--graceful-timeout", "30", \
    "--access-logfile", "-"]
