{
  "name": "fhir_rag",
  "version": "1.0.0",
  "description": "Production-ready FastAPI backend service for the FHIR RAG Chatbot, providing intelligent clinical data analysis through hybrid retrieval (SQL + Vector Search).",
  "main": "index.js",
  "scripts": {
    "install-backend": "cd backend && pip install -r requirements.txt",
    "frontend": "cd frontend && npm run dev",
    "backend": "cd backend && python -m uvicorn app.app:app --reload --host 0.0.0.0 --port 8000",
    "db:migrate": "cd backend && alembic upgrade head",
    "db:revision": "cd backend && alembic revision --autogenerate -m",
    "db:downgrade": "cd backend && alembic downgrade -1",
    "db:current": "cd backend && alembic current",
    "db:history": "cd backend && alembic history",
    "start": "concurrently \"npm run frontend\" \"npm run backend\""
  },
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
