# =============================================================================
# Data Insights AI-Copilot - Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# IMPORTANT: Clinical database connections are NOT configured here.
# They are managed via the frontend: Settings > Database Connections
# =============================================================================

# --- API Keys (Required) ---
OPENAI_API_KEY=sk-your-key-here

# --- Authentication ---
# Generate a strong secret: python3 -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=replace_this_with_a_secure_random_string_min_32_chars

# --- OIDC/Keycloak (Optional - leave empty to use local auth) ---
# OIDC_ISSUER_URL=https://keycloak.example.com/realms/your-realm
# OIDC_CLIENT_ID=data-insights-copilot

# --- Logging ---
LOG_LEVEL=INFO
LOG_FORMAT=json

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# =============================================================================
# NOTE: Clinical database connections (PostgreSQL/MySQL) are configured via
# the frontend Settings > Database Connections page, NOT in this file.
# =============================================================================
